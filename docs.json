{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "FlowWarden",
  "colors": {
    "primary": "#093375",
    "light": "#69b5d4",
    "dark": "#15803D"
  },
  "favicon": "/favicon.png",
