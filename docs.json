              "reporter/heartbeat",
              "reporter/instance-identity"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Annotations",
            "pages": [
              "reference/enable-flowwarden",
              "reference/change-stream",
              "reference/event-handlers",
              "reference/pipeline",
              "reference/filter",
              "reference/checkpoint",
              "reference/retry-policy",
              "reference/dead-letter-queue",
              "reference/on-error"
