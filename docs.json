            "group": "Guides",
            "pages": [
              "guides/imperative-vs-reactive",
              "guides/filtering-events",
              "guides/checkpoint-resume",
              "guides/retry-and-dlq",
              "guides/transactions",
              "guides/threading-and-scaling"
            ]
          }
        ]
      },
      {
        "tab": "Use Cases",
        "groups": [
          {
            "group": "Patterns",
            "pages": [
              "use-cases/cqrs",
              "use-cases/cdc",
              "use-cases/cache-invalidation",
              "use-cases/event-driven-notifications",
              "use-cases/audit-log"
            ]
          }
        ]
      },
      {
        "tab": "Javers",
        "groups": [
